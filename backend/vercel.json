{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "server.js"
        }
    ],
    "env": {
        "NODE_ENV": "production",
        "CORS_ORIGIN": "https://lcfrontend.vercel.app",
        "FRONTEND_URL": "https://lcfrontend.vercel.app"
    }
}